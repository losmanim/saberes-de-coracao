# =============================================
# Saberes de Coração — Configuração
# =============================================

# --- Servidor ---
PORT=3000

# --- Appwrite ---
# Criar projeto em: https://cloud.appwrite.io
APPWRITE_ENDPOINT=https://cloud.appwrite.io/v1
APPWRITE_PROJECT_ID=seu_project_id
APPWRITE_API_KEY=sua_api_key_admin
# Database IDs (criar via Appwrite Console)
APPWRITE_DATABASE_ID=seu_database_id
APPWRITE_SABERES_COLLECTION_ID=saberes
APPWRITE_CATEGORIAS_COLLECTION_ID=categorias
APPWRITE_MIDIA_COLLECTION_ID=midia
APPWRITE_CONTATOS_COLLECTION_ID=contatos
APPWRITE_USUARIOS_COLLECTION_ID=usuarios

# --- EmailJS ---
# Criar conta em: https://www.emailjs.com
EMAILJS_SERVICE_ID=seu_service_id
EMAILJS_TEMPLATE_ID=seu_template_id
EMAILJS_PUBLIC_KEY=sua_public_key
EMAILJS_PRIVATE_KEY=sua_private_key

# --- Admin (fallback se Appwrite Auth não estiver configurado) ---
ADMIN_PASS=admin123

# --- Mídia (Cloudinary ou Appwrite Storage) ---
MIDIA_BASE_URL=https://res.cloudinary.com/deblzssiw
